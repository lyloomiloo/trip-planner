# ─── Image Search (pick ONE, add your key) ─────────────────
# Both are free, no credit card needed.

# RECOMMENDED: Unsplash (50 req/hr free, high-quality travel photos)
# Sign up: https://unsplash.com/developers → New Application → copy Access Key
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# ALTERNATIVE: Pexels (200 req/hr free, good variety)
# Sign up: https://www.pexels.com/api/ → copy API Key
NEXT_PUBLIC_PEXELS_API_KEY=

# ─── Weather (free, no key needed) ─────────────────────────
# Uses Open-Meteo API — nothing to configure

# ─── Supabase (optional — enables cloud sync + sharing) ────
# Create a project at https://supabase.com (free tier)
# Then create a "trips" table — see CLAUDE.md for schema
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
